{
  "name": "dep-age",
  "version": "1.0.0",
  "description": "Show the age of every dependency in your package.json. Spot abandoned packages instantly.",
  "type": "module",
  "bin": {
    "dep-age": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
